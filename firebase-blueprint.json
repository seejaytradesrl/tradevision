{
  "entities": {
    "Trade": {
      "title": "Trade",
      "description": "A single trade record for a user.",
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "The stock symbol (e.g., AAPL)."
        },
        "entryPrice": {
          "type": "number",
          "description": "The price at which the trade was entered."
        },
        "quantity": {
          "type": "number",
          "description": "The number of shares or units traded."
        },
        "type": {
          "type": "string",
          "enum": ["buy", "sell"],
          "description": "The type of trade (buy or sell)."
        },
        "status": {
          "type": "string",
          "enum": ["open", "closed"],
          "description": "The current status of the trade."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this trade."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the trade was created."
        },
        "closedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the trade was closed."
        },
        "exitPrice": {
          "type": "number",
          "description": "The price at which the trade was closed."
        },
        "stopLoss": {
          "type": "number",
          "description": "The stop loss price level."
        },
        "takeProfit": {
          "type": "number",
          "description": "The take profit price level."
        }
      },
      "required": ["symbol", "entryPrice", "quantity", "type", "status", "userId", "createdAt", "stopLoss", "takeProfit"]
    },
    "User": {
      "title": "User",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role."
        }
      },
      "required": ["displayName", "email", "role"]
    }
  },
  "firestore": {
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Collection of all trades."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
